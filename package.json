{
  "name": "pm2-matrix",
  "version": "1.0.0",
  "description": "PM2 process monitor dashboard",
  "author": "Manfred J Ekblad",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/manfredjekblad/pm2-matrix.git"
  },
  "bugs": {
    "url": "https://github.com/manfredjekblad/pm2-matrix/issues"
  },
  "homepage": "https://github.com/manfredjekblad/pm2-matrix#readme",
  "main": "dist-server/index.js",
  "scripts": {
    "dev:server": "ts-node-dev --respawn --transpile-only src/server/index.ts",
    "dev:client": "vite",
    "build:client": "vite build",
    "typecheck:client": "tsc -p src/client/tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.json --noEmit",
    "typecheck": "npm run typecheck:client && npm run typecheck:server",
    "lint": "eslint \"src/server/**/*.ts\" \"src/client/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"src/server/**/*.ts\" \"src/client/**/*.{ts,tsx}\" --fix",
    "build:server": "tsc -p tsconfig.json",
    "build": "npm run build:client && npm run build:server",
    "start": "node dist-server/index.js",
    "generate-hash": "node -e \"const b=require('bcrypt');b.hash(process.argv[1],12).then(h=>console.log(h))\" --"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^8.2.1",
    "express-session": "^1.18.0",
    "helmet": "^8.1.0",
    "pm2": "^7.0.0",
    "session-file-store": "^1.5.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.17.10",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.2",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.1.0",
    "ansi-to-html": "^0.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
