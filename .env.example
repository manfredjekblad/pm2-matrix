PM2_MATRIX_USER=admin
PM2_MATRIX_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# SECURITY: 0.0.0.0 binds to ALL network interfaces, directly exposing this
# service to the internet.  When running behind a reverse proxy (Nginx, Caddy,
# etc.), set this to 127.0.0.1 so the app only accepts connections from the
# proxy running on the same machine.
PM2_MATRIX_HOST=0.0.0.0
PM2_MATRIX_PORT=8080

# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_RANDOM_64_CHAR_HEX_STRING

# Set to "production" to enable the Secure flag on session cookies, which
# prevents the cookie from being sent over plain HTTP.  Required when serving
# the app over HTTPS.  Also set TRUST_PROXY=1 if behind a reverse proxy.
NODE_ENV=production

# Set to 1 ONLY when running behind a reverse proxy (Nginx, Caddy, etc.).
# This enables Express to trust the X-Forwarded-For header for real client IP
# detection (used by the rate limiter).  Leave unset or set to 0 when the app
# is exposed directly to the internet to prevent IP spoofing attacks.
# Note: setting TRUST_PROXY=1 also enables the Secure cookie flag automatically.
TRUST_PROXY=0
