PM2_MATRIX_USER=admin
PM2_MATRIX_PASSWORD_HASH=$2b$12$your_bcrypt_hash_here

# SECURITY: 0.0.0.0 binds to ALL network interfaces, directly exposing this
# service to the internet.  When running behind a reverse proxy (Nginx, Caddy,
# etc.), set this to 127.0.0.1 so the app only accepts connections from the
# proxy running on the same machine.
PM2_MATRIX_HOST=0.0.0.0
PM2_MATRIX_PORT=8080

# Generate with: openssl rand -hex 32
# Or: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=REPLACE_WITH_A_RANDOM_64_CHAR_HEX_STRING

# Optional. Does not force Secure cookies — those follow HTTPS automatically
# (secure: 'auto'). Set TRUST_PROXY=1 when TLS terminates at a reverse proxy.
NODE_ENV=production

# Set to 1 ONLY when running behind a reverse proxy (Nginx, Caddy, etc.).
# This enables Express to trust X-Forwarded-For / X-Forwarded-Proto for real
# client IP detection (rate limiter) and correct HTTPS detection (Secure cookie).
# Leave unset or set to 0 when the app is exposed directly (including plain HTTP
# over Tailscale/VPN) to prevent IP spoofing attacks.
TRUST_PROXY=0
